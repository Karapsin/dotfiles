@define-color theme_bg_color #0c1116;
@define-color theme_fg_color #d7dde4;
@define-color theme_base_color #11161d;
@define-color theme_text_color #d7dde4;
@define-color theme_selected_bg_color #28445a;
@define-color theme_selected_fg_color #f4f7fb;
@define-color accent_bg_color #173348;
@define-color accent_fg_color #f4f7fb;
@define-color warning_color #f5c76f;
@define-color error_color #d26a6a;
@define-color border_color #28445a;
@define-color disabled_fg_color #8a949e;

* {
  background-image: none;
  color: @theme_fg_color;
  text-shadow: none;
  box-shadow: none;
}

.lightdm-gtk-greeter {
  background-color: transparent;
  color: @theme_fg_color;
  font: @DOTFILES_UI_RESOLVED_LIGHTDM_FONT_SIZE@ "Noto Sans";
}

#panel_window {
  background-color: alpha(#0c1116, 0.84);
  border-top: @DOTFILES_UI_RESOLVED_LIGHTDM_CONTROL_BORDER_WIDTH@px solid alpha(#6aa5d8, 0.35);
  color: @theme_fg_color;
  font-weight: 600;
  min-height: @DOTFILES_UI_RESOLVED_LIGHTDM_PANEL_HEIGHT@px;
}

#panel_window menubar,
#panel_window .menubar {
  min-height: @DOTFILES_UI_RESOLVED_LIGHTDM_PANEL_HEIGHT@px;
}

#panel_window menubar,
#panel_window menuitem,
#panel_window .menubar > .menuitem {
  background-color: transparent;
  color: @theme_fg_color;
}

#panel_window menubar > menuitem,
#panel_window .menubar > .menuitem {
  min-height: @DOTFILES_UI_RESOLVED_LIGHTDM_PANEL_HEIGHT@px;
  padding: 0 @DOTFILES_UI_RESOLVED_LIGHTDM_PANEL_ITEM_PADDING_X@px;
}

#panel_window menu,
#panel_window .menu {
  background-color: @theme_base_color;
  border: @DOTFILES_UI_RESOLVED_LIGHTDM_CONTROL_BORDER_WIDTH@px solid @border_color;
  border-radius: @DOTFILES_UI_RESOLVED_LIGHTDM_CONTROL_RADIUS@px;
  padding: @DOTFILES_UI_RESOLVED_LIGHTDM_MENU_PADDING@px;
}

#panel_window menuitem:hover,
#panel_window menuitem:selected,
#panel_window .menuitem:hover,
#panel_window .menuitem:selected {
  background-color: @theme_selected_bg_color;
  color: @theme_selected_fg_color;
}

#login_window,
#shutdown_dialog,
#restart_dialog {
  background-color: alpha(#0c1116, 0.92);
  border: @DOTFILES_UI_RESOLVED_LIGHTDM_CARD_BORDER_WIDTH@px solid alpha(#6aa5d8, 0.45);
  border-radius: @DOTFILES_UI_RESOLVED_LIGHTDM_CARD_RADIUS@px;
  color: @theme_fg_color;
  padding: @DOTFILES_UI_RESOLVED_LIGHTDM_CARD_PADDING@px;
  box-shadow:
    0 @DOTFILES_UI_RESOLVED_LIGHTDM_CARD_SHADOW_Y@px @DOTFILES_UI_RESOLVED_LIGHTDM_CARD_SHADOW_BLUR@px alpha(#000000, 0.36),
    inset 0 @DOTFILES_UI_RESOLVED_LIGHTDM_CARD_BORDER_WIDTH@px alpha(#ffffff, 0.06);
}

#content_frame {
  padding: @DOTFILES_UI_RESOLVED_LIGHTDM_CONTENT_PADDING_TOP@px @DOTFILES_UI_RESOLVED_LIGHTDM_CONTENT_PADDING_X@px @DOTFILES_UI_RESOLVED_LIGHTDM_CONTENT_PADDING_BOTTOM@px;
}

#buttonbox_frame {
  background-color: alpha(#11161d, 0.76);
  border-top: @DOTFILES_UI_RESOLVED_LIGHTDM_CONTROL_BORDER_WIDTH@px solid alpha(#6aa5d8, 0.18);
  border-bottom-left-radius: @DOTFILES_UI_RESOLVED_LIGHTDM_CARD_RADIUS@px;
  border-bottom-right-radius: @DOTFILES_UI_RESOLVED_LIGHTDM_CARD_RADIUS@px;
  padding: @DOTFILES_UI_RESOLVED_LIGHTDM_BUTTONBOX_PADDING_TOP@px @DOTFILES_UI_RESOLVED_LIGHTDM_BUTTONBOX_PADDING_X@px @DOTFILES_UI_RESOLVED_LIGHTDM_BUTTONBOX_PADDING_BOTTOM@px;
}

#login_window label,
#shutdown_dialog label,
#restart_dialog label {
  color: @theme_fg_color;
}

#user_image {
  background-color: alpha(#173348, 0.72);
  border-radius: @DOTFILES_UI_RESOLVED_LIGHTDM_AVATAR_RADIUS@px;
  padding: @DOTFILES_UI_RESOLVED_LIGHTDM_AVATAR_PADDING@px;
}

#user_image_border {
  background-color: alpha(#11161d, 0.82);
  border: @DOTFILES_UI_RESOLVED_LIGHTDM_AVATAR_BORDER_WIDTH@px solid alpha(#6aa5d8, 0.34);
  border-radius: @DOTFILES_UI_RESOLVED_LIGHTDM_AVATAR_RADIUS@px;
  padding: @DOTFILES_UI_RESOLVED_LIGHTDM_AVATAR_BORDER_PADDING@px;
}

#user_combobox,
#login_window combobox,
#login_window combobox button,
#login_window GtkComboBox,
#login_window GtkComboBox .button {
  background-color: transparent;
  border: 0;
  color: @theme_selected_fg_color;
  font-size: @DOTFILES_UI_RESOLVED_LIGHTDM_TITLE_FONT_SIZE@px;
  font-weight: 600;
}

#login_window menu,
#login_window .menu {
  background-color: @theme_base_color;
  border: @DOTFILES_UI_RESOLVED_LIGHTDM_CONTROL_BORDER_WIDTH@px solid @border_color;
  border-radius: @DOTFILES_UI_RESOLVED_LIGHTDM_CONTROL_RADIUS@px;
}

#login_window menuitem,
#login_window .menuitem {
  color: @theme_fg_color;
  padding: @DOTFILES_UI_RESOLVED_LIGHTDM_MENUITEM_PADDING_Y@px @DOTFILES_UI_RESOLVED_LIGHTDM_MENUITEM_PADDING_X@px;
}

#login_window menuitem:hover,
#login_window menuitem:selected,
#login_window .menuitem:hover,
#login_window .menuitem:selected {
  background-color: @theme_selected_bg_color;
  color: @theme_selected_fg_color;
}

entry,
.entry,
#login_window entry,
#login_window .entry {
  background-color: alpha(#11161d, 0.95);
  border: @DOTFILES_UI_RESOLVED_LIGHTDM_CONTROL_BORDER_WIDTH@px solid @border_color;
  border-radius: @DOTFILES_UI_RESOLVED_LIGHTDM_CONTROL_RADIUS@px;
  color: @theme_text_color;
  caret-color: #9ccfd8;
  min-height: @DOTFILES_UI_RESOLVED_LIGHTDM_ENTRY_MIN_HEIGHT@px;
  padding: @DOTFILES_UI_RESOLVED_LIGHTDM_ENTRY_PADDING_Y@px @DOTFILES_UI_RESOLVED_LIGHTDM_ENTRY_PADDING_X@px;
}

entry:focus,
.entry:focus,
#login_window entry:focus,
#login_window .entry:focus {
  background-color: #11161d;
  border-color: #6aa5d8;
  box-shadow: inset 0 0 0 @DOTFILES_UI_RESOLVED_LIGHTDM_CONTROL_BORDER_WIDTH@px alpha(#6aa5d8, 0.28);
}

button,
.button,
#login_window button,
#login_window .button,
#shutdown_dialog button,
#shutdown_dialog .button,
#restart_dialog button,
#restart_dialog .button {
  background-color: @accent_bg_color;
  border: @DOTFILES_UI_RESOLVED_LIGHTDM_CONTROL_BORDER_WIDTH@px solid @border_color;
  border-radius: @DOTFILES_UI_RESOLVED_LIGHTDM_CONTROL_RADIUS@px;
  color: @accent_fg_color;
  min-height: @DOTFILES_UI_RESOLVED_LIGHTDM_BUTTON_MIN_HEIGHT@px;
  padding: @DOTFILES_UI_RESOLVED_LIGHTDM_BUTTON_PADDING_Y@px @DOTFILES_UI_RESOLVED_LIGHTDM_BUTTON_PADDING_X@px;
}

button:hover,
.button:hover,
#login_window button:hover,
#login_window .button:hover,
#shutdown_dialog button:hover,
#shutdown_dialog .button:hover,
#restart_dialog button:hover,
#restart_dialog .button:hover {
  background-color: #23516f;
  border-color: #6aa5d8;
}

button:focus,
.button:focus,
button.default,
.button.default,
#login_window button:focus,
#login_window .button:focus,
#login_window .button.default {
  background-color: #23516f;
  border-color: #9ccfd8;
  box-shadow: inset 0 0 0 @DOTFILES_UI_RESOLVED_LIGHTDM_CONTROL_BORDER_WIDTH@px alpha(#9ccfd8, 0.34);
  color: #ffffff;
}

#shutdown_button,
#shutdown_button.button {
  background-color: #3a1b23;
  border-color: @error_color;
  color: #ffffff;
}

#shutdown_button:hover,
#shutdown_button.button:hover {
  background-color: #4a2029;
  border-color: #e58b8b;
}

#restart_button,
#restart_button.button {
  background-color: #3a2f1a;
  border-color: @warning_color;
  color: #ffffff;
}

#restart_button:hover,
#restart_button.button:hover {
  background-color: #46391f;
  border-color: #f7d997;
}

*:disabled {
  color: @disabled_fg_color;
}
