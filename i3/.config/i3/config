# i3 config

# Variables
set $mod Mod4
set $i3dir $HOME/.config/i3
set $rail_output HDMI-0

set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

font pango:monospace 8
floating_modifier $mod
tiling_drag modifier titlebar
hide_edge_borders smart

# Autostart
exec_always --no-startup-id xrandr --output DP-0 --mode 2560x1440 --rate 143.97
exec --no-startup-id $i3dir/session-start.sh
exec --no-startup-id $HOME/.config/polybar/launch.sh restart
exec_always --no-startup-id $HOME/.local/bin/load-xkb-shortcuts

# System keys
bindsym XF86AudioRaiseVolume exec --no-startup-id pamixer --increase 5
bindsym XF86AudioLowerVolume exec --no-startup-id pamixer --decrease 5
bindsym XF86AudioMute exec --no-startup-id pamixer --toggle-mute

bindsym $mod+Shift+c exec --no-startup-id $HOME/.config/polybar/calendar.sh --popup
bindsym $mod+Shift+r restart
bindsym $mod+Shift+q kill

# Launchers
bindcode $mod+36 fullscreen disable; exec --no-startup-id $i3dir/launch-terminal.sh
bindcode $mod+104 fullscreen disable; exec --no-startup-id $i3dir/launch-terminal.sh
bindsym $mod+d fullscreen disable; exec --no-startup-id rofi -show drun
# bindsym $mod+d exec --no-startup-id dmenu_run

bindsym $mod+Shift+e exec --no-startup-id nemo --no-desktop
bindsym $mod+Shift+s exec --no-startup-id flameshot gui
bindsym $mod+Shift+l exec --no-startup-id betterlockscreen -l
bindsym $mod+Shift+p exec --no-startup-id $HOME/.config/polybar/powermenu.sh
bindsym $mod+c exec --no-startup-id google-chrome-stable
bindsym $mod+g exec --no-startup-id steam
bindsym $mod+t exec --no-startup-id Telegram
bindsym $mod+Shift+v exec --no-startup-id $i3dir/vpn-control-toggle.sh
bindsym $mod+Mod1+v exec --no-startup-id pavucontrol --tab=1
bindsym $mod+Mod1+b exec --no-startup-id $i3dir/blueman-launch.sh --manager
bindsym $mod+Shift+t exec --no-startup-id element-desktop
bindsym $mod+p exec --no-startup-id positron
bindsym $mod+Mod1+r exec --no-startup-id rstudio

# Focus
bindsym $mod+j exec --no-startup-id $i3dir/focus-visual.py left
bindsym $mod+k exec --no-startup-id $i3dir/focus-visual.py down
bindsym $mod+l exec --no-startup-id $i3dir/focus-visual.py up
bindsym $mod+semicolon exec --no-startup-id $i3dir/focus-visual.py right
bindsym $mod+Left exec --no-startup-id $i3dir/focus-visual.py left
bindsym $mod+Down exec --no-startup-id $i3dir/focus-visual.py down
bindsym $mod+Up exec --no-startup-id $i3dir/focus-visual.py up
bindsym $mod+Right exec --no-startup-id $i3dir/focus-visual.py right

# Move windows
bindsym $mod+Shift+j move left
bindsym $mod+Shift+k move down
bindsym $mod+Shift+semicolon move right
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# Layout
bindsym $mod+h split v
bindsym $mod+v split h
bindsym $mod+f fullscreen toggle
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split
bindsym $mod+Shift+space floating toggle
# $mod+space is reserved for keyboard layout switching via XKB.
bindsym $mod+a focus parent

# Workspaces
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# Resize mode
mode "resize" {
        bindsym j resize shrink width 10 px or 10 ppt
        bindsym k resize grow height 10 px or 10 ppt
        bindsym l resize shrink height 10 px or 10 ppt
        bindsym semicolon resize grow width 10 px or 10 ppt

        bindsym Left resize shrink width 10 px or 10 ppt
        bindsym Down resize grow height 10 px or 10 ppt
        bindsym Up resize shrink height 10 px or 10 ppt
        bindsym Right resize grow width 10 px or 10 ppt

        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+r mode "default"
}
bindsym $mod+r mode "resize"

# Window rules
for_window [class="Gsimplecal"] floating enable, border none, move scratchpad
for_window [class="^pavucontrol$"] floating enable, resize set 680 520, move position mouse, move up 3 ppt
for_window [class="^Blueman-manager$"] floating enable, resize set 560 480, move position mouse, move up 3 ppt
for_window [instance="^RAIL$"] move to output $rail_output, floating enable, sticky disable, focus, move position center
for_window [class="^RAIL(:.*)?$"] move to output $rail_output, floating enable, sticky disable, focus, move position center

# Window colors
client.focused          #28445a #17212b #d7dde4 #173348 #28445a
client.focused_inactive #17212b #151b24 #8a949e #17212b #17212b
client.unfocused        #17212b #151b24 #8a949e #17212b #17212b
client.urgent           #d26a6a #d26a6a #0c1116 #ef8f8f #d26a6a
client.placeholder      #11161d #0c1116 #8a949e #11161d #11161d
client.background       #0c1116
