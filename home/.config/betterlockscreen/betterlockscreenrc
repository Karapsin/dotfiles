# betterlockscreen sources this file as Bash.
# Show the current XKB layout on the lock screen.
lockargs+=(--keylayout 0)

# Keep the lock screen aligned with the dark blue desktop palette.
font="Noto Sans"
locktext="Locked"
veriftext="Checking..."
wrongtext="Try again"
time_format="%H:%M"
lock_timeout=60

bgcolor=0c1116ff
loginbox=0c1116b3
loginshadow=00000066
separatorcolor=00000000
layoutcolor=65a6d9ff
greetercolor=d7dde4ff
timecolor=d7dde4ff
ringcolor=3a607dff
keyhlcolor=65a6d9ff
bshlcolor=d26a6aff
verifcolor=65a6d9ff
wrongcolor=d26a6aff
modifcolor=65a6d9ff
insidecolor=00000000
insidevercolor=00000000
insidewrongcolor=d26a6a66
ringvercolor=65a6d9ff
ringwrongcolor=d26a6aff
