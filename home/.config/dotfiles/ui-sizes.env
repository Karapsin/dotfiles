# Shared UI sizing defaults.
#
# Edit this file, then run:
#   ~/.config/dotfiles/update-ui.sh
#
# Values use shell-style assignments and are sourced by dotfiles scripts.
# Quote values that contain spaces, semicolons, or units such as pt/em.
# Plain integers are pixels unless the variable name or comment says otherwise.

# Baseline geometry used by global area scaling.
# These should describe the workspace area the current defaults were tuned on.
export DOTFILES_UI_SCREEN_BASE_WIDTH=2560
export DOTFILES_UI_SCREEN_BASE_HEIGHT=1398
export DOTFILES_UI_SCALE_MIN_PERCENT=75
export DOTFILES_UI_SCALE_MAX_PERCENT=180

# Xresources-backed global sizing.
# i3 reads the font and resize-step values via set_from_resource.
export DOTFILES_UI_XFT_DPI=96
export DOTFILES_UI_I3_FONT_SIZE=8
export DOTFILES_UI_I3_RESIZE_STEP=10

# Shared popup margins.
# EDGE_GAP keeps floating windows away from screen edges.
# BOTTOM_GAP keeps popups above Polybar after bar clearance is calculated.
export DOTFILES_UI_POPUP_EDGE_GAP=8
export DOTFILES_UI_POPUP_BOTTOM_GAP=0

# PulseAudio popup opened by $mod+Alt+v or PulseAudio tray left-click.
# Base and minimum dimensions are resolved from the active workspace scale.
export DOTFILES_UI_VOLUME_BASE_WINDOW_WIDTH=540
export DOTFILES_UI_VOLUME_BASE_WINDOW_HEIGHT=520
export DOTFILES_UI_VOLUME_MIN_WINDOW_WIDTH=540
export DOTFILES_UI_VOLUME_MIN_WINDOW_HEIGHT=360

# Blueman manager popup opened by $mod+Alt+b or Bluetooth tray left-click.
# Tray max icon values filter out Blueman popup-menu windows that share
# the same X11 class as the real tray icon.
# Base, minimum, and tray filter dimensions are resolved from the active
# workspace scale.
export DOTFILES_UI_BLUETOOTH_BASE_WINDOW_WIDTH=560
export DOTFILES_UI_BLUETOOTH_BASE_WINDOW_HEIGHT=480
export DOTFILES_UI_BLUETOOTH_MIN_WINDOW_WIDTH=420
export DOTFILES_UI_BLUETOOTH_MIN_WINDOW_HEIGHT=180
export DOTFILES_UI_BLUETOOTH_TRAY_MAX_ICON_WIDTH=80
export DOTFILES_UI_BLUETOOTH_TRAY_MAX_ICON_HEIGHT=80

# Rofi power menu opened by Polybar or $mod+Shift+p.
# BASE_X_OFFSET is scaled from screen width and anchors the menu near
# the left edge above Polybar.
export DOTFILES_UI_POWERMENU_BASE_WIDTH=180
export DOTFILES_UI_POWERMENU_MIN_WIDTH=100
export DOTFILES_UI_POWERMENU_BASE_X_OFFSET=9
export DOTFILES_UI_POWERMENU_FONT_BASE_SIZE=12
export DOTFILES_UI_POWERMENU_FONT_MIN_SIZE=12
export DOTFILES_UI_POWERMENU_MAINBOX_PADDING='0.25em'
export DOTFILES_UI_POWERMENU_MAINBOX_SPACING='0.25em'
export DOTFILES_UI_POWERMENU_LIST_LINES=3
export DOTFILES_UI_POWERMENU_LIST_SPACING='0.15em'
export DOTFILES_UI_POWERMENU_ELEMENT_PADDING_Y='0.25em'
export DOTFILES_UI_POWERMENU_ELEMENT_PADDING_X='0.25em'
export DOTFILES_UI_POWERMENU_ELEMENT_SPACING='0em'

# Polybar calendar popup sizing.
# PERMILLE values are thousandths of workspace width/height.
# Font/border values are base pixels and are resolved through global scaling.
export DOTFILES_UI_CALENDAR_FALLBACK_WIDTH_PERMILLE=92
export DOTFILES_UI_CALENDAR_FALLBACK_HEIGHT_PERMILLE=124
export DOTFILES_UI_CALENDAR_FALLBACK_CHAR_WIDTH_PERMILLE=7
export DOTFILES_UI_CALENDAR_MARGIN_PERMILLE=6
export DOTFILES_UI_CALENDAR_GAP_PERMILLE=6
export DOTFILES_UI_CALENDAR_FONT_BASE_PX=13
export DOTFILES_UI_CALENDAR_FONT_MIN_PX=10
export DOTFILES_UI_CALENDAR_BORDER_BASE_PX=1
export DOTFILES_UI_CALENDAR_BORDER_MIN_PX=1
export DOTFILES_UI_CALENDAR_HEADER_SPACING=5
export DOTFILES_UI_CALENDAR_YEAR_NAV_GAP=8

# Shortcut cheatsheet Rofi window opened by $mod+Shift+/.
# COLUMN_WIDTH is the padded monospace shortcut column in generated rows.
export DOTFILES_UI_SHORTCUT_CHEATSHEET_WIDTH=900
export DOTFILES_UI_SHORTCUT_CHEATSHEET_LINES=24
export DOTFILES_UI_SHORTCUT_CHEATSHEET_COLUMN_WIDTH=43

# Polybar bar and tray sizing.
# BAR_HEIGHT is the main bar height; increasing it makes the whole bar taller.
# Font values use Polybar font syntax and usually need quotes.
export DOTFILES_UI_POLYBAR_DPI=96
export DOTFILES_UI_POLYBAR_BAR_HEIGHT='28pt'
export DOTFILES_UI_POLYBAR_LINE_SIZE='3pt'
export DOTFILES_UI_POLYBAR_BORDER_SIZE='0pt'
export DOTFILES_UI_POLYBAR_PADDING_LEFT=1
export DOTFILES_UI_POLYBAR_PADDING_RIGHT=1
export DOTFILES_UI_POLYBAR_MODULE_MARGIN=1
export DOTFILES_UI_POLYBAR_WORKSPACE_LABEL_PADDING=1
export DOTFILES_UI_POLYBAR_KEYBOARD_INDICATOR_PADDING=2
export DOTFILES_UI_POLYBAR_KEYBOARD_INDICATOR_MARGIN=1
export DOTFILES_UI_POLYBAR_TITLE_MAXLEN=60
export DOTFILES_UI_POLYBAR_FONT_0='Noto Sans Mono,Liberation Mono,DejaVu Sans Mono:size=12;2'
export DOTFILES_UI_POLYBAR_FONT_1='Font Awesome 7 Free:style=Solid:size=12;2'
export DOTFILES_UI_POLYBAR_FONT_2='Symbols Nerd Font Mono:size=12;2'
export DOTFILES_UI_POLYBAR_TRAY_MARGIN='0pt'
export DOTFILES_UI_POLYBAR_TRAY_PADDING='2pt'
export DOTFILES_UI_POLYBAR_TRAY_SPACING='8pt'

