export DOTFILES_UI_LIGHTDM_CARD_RADIUS=8
export DOTFILES_UI_LIGHTDM_CARD_PADDING=18
export DOTFILES_UI_LIGHTDM_CARD_SHADOW_Y=18
export DOTFILES_UI_LIGHTDM_CARD_SHADOW_BLUR=48
export DOTFILES_UI_LIGHTDM_CONTENT_PADDING_TOP=18
export DOTFILES_UI_LIGHTDM_CONTENT_PADDING_X=20
export DOTFILES_UI_LIGHTDM_CONTENT_PADDING_BOTTOM=12
export DOTFILES_UI_LIGHTDM_BUTTONBOX_PADDING_TOP=14
export DOTFILES_UI_LIGHTDM_BUTTONBOX_PADDING_X=20
export DOTFILES_UI_LIGHTDM_BUTTONBOX_PADDING_BOTTOM=18
export DOTFILES_UI_LIGHTDM_AVATAR_PADDING=4
export DOTFILES_UI_LIGHTDM_AVATAR_BORDER_WIDTH=1
export DOTFILES_UI_LIGHTDM_AVATAR_BORDER_PADDING=2
export DOTFILES_UI_LIGHTDM_AVATAR_RADIUS=999
export DOTFILES_UI_LIGHTDM_TITLE_FONT_SIZE=18
export DOTFILES_UI_LIGHTDM_ENTRY_MIN_HEIGHT=34
export DOTFILES_UI_LIGHTDM_ENTRY_PADDING_Y=7
export DOTFILES_UI_LIGHTDM_ENTRY_PADDING_X=10
export DOTFILES_UI_LIGHTDM_BUTTON_MIN_HEIGHT=32
export DOTFILES_UI_LIGHTDM_BUTTON_PADDING_Y=6
export DOTFILES_UI_LIGHTDM_BUTTON_PADDING_X=16
export DOTFILES_UI_LIGHTDM_CONTROL_BORDER_WIDTH=1
export DOTFILES_UI_LIGHTDM_CONTROL_RADIUS=5

# Global GTK 3/4 generated CSS dimensions.
# These affect generated gtk.css files after update-ui.sh or bootstrap.
export DOTFILES_UI_GTK3_TAB_PADDING_Y=7
export DOTFILES_UI_GTK3_TAB_PADDING_X=12
export DOTFILES_UI_GTK4_TAB_PADDING_Y=8
export DOTFILES_UI_GTK4_TAB_PADDING_X=14
export DOTFILES_UI_GTK_ACTIVE_BORDER_WIDTH=3
export DOTFILES_UI_GTK_CONTROL_BORDER_WIDTH=1
export DOTFILES_UI_GTK_CONTROL_RADIUS=5
export DOTFILES_UI_GTK_SCALE_TROUGH_HEIGHT=4
export DOTFILES_UI_GTK_SCALE_SLIDER_BORDER_WIDTH=1
export DOTFILES_UI_GTK_SCALE_SLIDER_SIZE=16
export DOTFILES_UI_GTK_SEPARATOR_HEIGHT=1
export DOTFILES_UI_GTK_PILL_RADIUS=999

# Gsimplecal/custom calendar GTK CSS dimensions.
# These values are em units and are applied when the calendar script renders
# its runtime GTK CSS.
export DOTFILES_UI_GSIMPLECAL_WINDOW_RADIUS_EM='0.46'
export DOTFILES_UI_GSIMPLECAL_PADDING_EM='0.62'
export DOTFILES_UI_GSIMPLECAL_BUTTON_PADDING_Y_EM='0.15'
export DOTFILES_UI_GSIMPLECAL_BUTTON_PADDING_X_EM='0.46'
export DOTFILES_UI_GSIMPLECAL_BUTTON_RADIUS_EM='0.31'
export DOTFILES_UI_GSIMPLECAL_POPUP_PADDING_EM='0.52'
export DOTFILES_UI_GSIMPLECAL_HEADER_MARGIN_EM='0.42'
export DOTFILES_UI_GSIMPLECAL_NAV_RADIUS_EM='0.32'
export DOTFILES_UI_GSIMPLECAL_NAV_MIN_SIZE_EM='1.45'
export DOTFILES_UI_GSIMPLECAL_WEEKDAY_MIN_HEIGHT_EM='1.8'
export DOTFILES_UI_GSIMPLECAL_WEEKDAY_MIN_WIDTH_EM='2.45'
export DOTFILES_UI_GSIMPLECAL_DAY_RADIUS_EM='0.42'

# Main Rofi theme dimensions for launchers and menus that use the shared theme.
export DOTFILES_UI_ROFI_FONT='Noto Sans 11'
export DOTFILES_UI_ROFI_WINDOW_WIDTH=720
export DOTFILES_UI_ROFI_WINDOW_BORDER=1
export DOTFILES_UI_ROFI_WINDOW_RADIUS=6
export DOTFILES_UI_ROFI_MAINBOX_PADDING=10
export DOTFILES_UI_ROFI_MAINBOX_SPACING=8
