# Picom compositor visual sizing.
# Negative shadow offsets keep the current upper-left shadow direction.
export DOTFILES_UI_PICOM_SHADOW_RADIUS=7
export DOTFILES_UI_PICOM_SHADOW_OFFSET_X=-7
export DOTFILES_UI_PICOM_SHADOW_OFFSET_Y=-7
export DOTFILES_UI_PICOM_CORNER_RADIUS=0

# Betterlockscreen/i3lock-color typography and indicator geometry.
