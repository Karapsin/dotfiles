@define-color theme_bg_color #0c1116;
@define-color theme_fg_color #d7dde4;
@define-color theme_base_color #11161d;
@define-color theme_text_color #d7dde4;
@define-color theme_selected_bg_color #28445a;
@define-color theme_selected_fg_color #f4f7fb;
@define-color accent_bg_color #173348;
@define-color accent_fg_color #f4f7fb;
@define-color warning_color #f5c76f;
@define-color error_color #d26a6a;
@define-color border_color #28445a;
@define-color disabled_fg_color #8a949e;
@define-color window_bg_color @theme_bg_color;
@define-color window_fg_color @theme_fg_color;
@define-color view_bg_color @theme_base_color;
@define-color view_fg_color @theme_text_color;
@define-color dialog_bg_color @theme_bg_color;
@define-color dialog_fg_color @theme_fg_color;
@define-color headerbar_bg_color #151b24;
@define-color popover_bg_color @theme_base_color;
@define-color popover_fg_color @theme_fg_color;

* {
  background-image: none;
  color: @theme_fg_color;
  text-shadow: none;
  box-shadow: none;
}

window,
window.background,
.background {
  background-color: @theme_bg_color;
  color: @theme_fg_color;
}

window.background.csd,
window.background.ssd,
window.aboutdialog,
window.aboutdialog.background,
window.aboutdialog.csd.background,
messagedialog,
messagedialog.background,
messagedialog.csd.background,
dialog,
dialog.background,
.dialog-vbox,
.dialog-vbox > box,
.dialog-action-area {
  background: @theme_bg_color;
  background-color: @theme_bg_color;
  color: @theme_fg_color;
}

window.aboutdialog box,
window.aboutdialog grid,
window.aboutdialog image,
messagedialog box,
messagedialog grid,
dialog box,
dialog grid {
  background-color: transparent;
  color: @theme_fg_color;
}

headerbar,
.titlebar,
menubar,
toolbar,
statusbar {
  background-color: #151b24;
  color: @theme_fg_color;
  border-color: @border_color;
}

menu,
menuitem,
popover,
popover.background {
  background-color: @theme_base_color;
  color: @theme_fg_color;
}

menuitem:hover,
menuitem:selected {
  background-color: @theme_selected_bg_color;
  color: @theme_selected_fg_color;
}

notebook,
notebook stack,
viewport,
scrolledwindow,
box,
paned,
.view,
treeview,
list,
row {
  background-color: @theme_bg_color;
  color: @theme_fg_color;
}

notebook header {
  background-color: #151b24;
  border-bottom: @DOTFILES_UI_RESOLVED_GTK_CONTROL_BORDER_WIDTH@px solid @border_color;
}

notebook tab {
  background-color: #151b24;
  color: @theme_fg_color;
  border-color: transparent;
  padding: @DOTFILES_UI_RESOLVED_GTK3_TAB_PADDING_Y@px @DOTFILES_UI_RESOLVED_GTK3_TAB_PADDING_X@px;
}

notebook tab:hover {
  background-color: #17212b;
}

notebook tab:checked {
  background-color: @accent_bg_color;
  color: @accent_fg_color;
  border-bottom: @DOTFILES_UI_RESOLVED_GTK_ACTIVE_BORDER_WIDTH@px solid #9ccfd8;
}

button,
combobox,
combobox button,
entry,
spinbutton {
  background-color: @theme_base_color;
  color: @theme_fg_color;
  border: @DOTFILES_UI_RESOLVED_GTK_CONTROL_BORDER_WIDTH@px solid @border_color;
  border-radius: @DOTFILES_UI_RESOLVED_GTK_CONTROL_RADIUS@px;
}

button:hover,
combobox button:hover {
  background-color: #17212b;
  border-color: #6f9fb0;
}

button:checked,
button:active {
  background-color: @accent_bg_color;
  color: @accent_fg_color;
  border-color: #6f9fb0;
}

button:disabled,
label:disabled,
entry:disabled,
treeview.view:disabled {
  color: @disabled_fg_color;
}

treeview.view:selected,
treeview.view:selected:focus,
row:hover,
row:selected,
*:selected {
  background-color: @theme_selected_bg_color;
  color: @theme_selected_fg_color;
}

scale trough {
  background-color: #29313a;
  border-radius: @DOTFILES_UI_RESOLVED_GTK_PILL_RADIUS@px;
  min-height: @DOTFILES_UI_RESOLVED_GTK_SCALE_TROUGH_HEIGHT@px;
}

scale highlight {
  background-color: #6aa5d8;
  border-radius: @DOTFILES_UI_RESOLVED_GTK_PILL_RADIUS@px;
}

scale slider {
  background-color: #d7dde4;
  border: @DOTFILES_UI_RESOLVED_GTK_SCALE_SLIDER_BORDER_WIDTH@px solid #8a949e;
  border-radius: @DOTFILES_UI_RESOLVED_GTK_PILL_RADIUS@px;
  min-width: @DOTFILES_UI_RESOLVED_GTK_SCALE_SLIDER_SIZE@px;
  min-height: @DOTFILES_UI_RESOLVED_GTK_SCALE_SLIDER_SIZE@px;
}

switch {
  background-color: #29313a;
  border: @DOTFILES_UI_RESOLVED_GTK_CONTROL_BORDER_WIDTH@px solid @border_color;
  border-radius: @DOTFILES_UI_RESOLVED_GTK_PILL_RADIUS@px;
}

switch:checked {
  background-color: #173348;
  border-color: #6aa5d8;
}

switch slider {
  background-color: #d7dde4;
  border-radius: @DOTFILES_UI_RESOLVED_GTK_PILL_RADIUS@px;
}

separator {
  background-color: @border_color;
  min-height: @DOTFILES_UI_RESOLVED_GTK_SEPARATOR_HEIGHT@px;
}
