# Keep compositing predictable: no fades or launch/workspace transition effects.
backend = "xrender";
vsync = true;
use-damage = true;

fading = false;
no-fading-openclose = true;
no-fading-destroyed-argb = true;
fade-in-step = 1.0;
fade-out-step = 1.0;
fade-delta = 1;

shadow = true;
shadow-radius = @DOTFILES_UI_RESOLVED_PICOM_SHADOW_RADIUS@;
shadow-offset-x = @DOTFILES_UI_RESOLVED_PICOM_SHADOW_OFFSET_X@;
shadow-offset-y = @DOTFILES_UI_RESOLVED_PICOM_SHADOW_OFFSET_Y@;

frame-opacity = 1.0;
corner-radius = @DOTFILES_UI_RESOLVED_PICOM_CORNER_RADIUS@;
detect-rounded-corners = true;
detect-client-opacity = true;
detect-transient = true;
