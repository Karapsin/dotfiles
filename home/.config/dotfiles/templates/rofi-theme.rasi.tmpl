* {
    bg:             #101820;
    bg-alt:         #172331;
    bg-selected:    #23516F;
    fg:             #E5EAF0;
    fg-muted:       #9AA7B2;
    border:         #3A78A2;
    urgent:         #A54242;

    background-color: transparent;
    text-color:       @fg;
}

window {
    width: @DOTFILES_UI_RESOLVED_ROFI_WINDOW_WIDTH@px;
    padding: 0;
    border: @DOTFILES_UI_RESOLVED_ROFI_WINDOW_BORDER@px;
    border-color: @border;
    border-radius: @DOTFILES_UI_RESOLVED_ROFI_WINDOW_RADIUS@px;
    background-color: @bg;
}

mainbox {
    padding: @DOTFILES_UI_RESOLVED_ROFI_MAINBOX_PADDING@px;
    spacing: @DOTFILES_UI_RESOLVED_ROFI_MAINBOX_SPACING@px;
    background-color: @bg;
}

inputbar {
    padding: @DOTFILES_UI_RESOLVED_ROFI_INPUT_PADDING_Y@px @DOTFILES_UI_RESOLVED_ROFI_INPUT_PADDING_X@px;
    spacing: @DOTFILES_UI_RESOLVED_ROFI_INPUT_SPACING@px;
    border: @DOTFILES_UI_RESOLVED_ROFI_INPUT_BORDER@px;
    border-color: #263645;
    border-radius: @DOTFILES_UI_RESOLVED_ROFI_INPUT_RADIUS@px;
    background-color: @bg-alt;
    children: [ prompt, entry ];
}

prompt {
    text-color: @fg-muted;
}

entry {
    placeholder: "Search";
    placeholder-color: @fg-muted;
    text-color: @fg;
}

listview {
    lines: @DOTFILES_UI_RESOLVED_ROFI_LIST_LINES@;
    columns: 1;
    fixed-height: true;
    spacing: @DOTFILES_UI_RESOLVED_ROFI_LIST_SPACING@px;
    scrollbar: false;
    background-color: transparent;
}

element {
    padding: @DOTFILES_UI_RESOLVED_ROFI_ELEMENT_PADDING_Y@px @DOTFILES_UI_RESOLVED_ROFI_ELEMENT_PADDING_X@px;
    spacing: @DOTFILES_UI_RESOLVED_ROFI_ELEMENT_SPACING@px;
    border-radius: @DOTFILES_UI_RESOLVED_ROFI_ELEMENT_RADIUS@px;
    background-color: transparent;
}

element-icon {
    size: @DOTFILES_UI_RESOLVED_ROFI_ELEMENT_ICON_SIZE_EM@em;
    background-color: transparent;
}

element-text {
    vertical-align: 0.5;
    background-color: transparent;
    text-color: inherit;
}

element normal.normal {
    text-color: @fg;
}

element normal.urgent {
    text-color: @urgent;
}

element selected.normal,
element selected.active {
    background-color: @bg-selected;
    text-color: #FFFFFF;
}

element alternate.normal {
    background-color: transparent;
}

message {
    padding: @DOTFILES_UI_RESOLVED_ROFI_MESSAGE_PADDING@px;
    border: @DOTFILES_UI_RESOLVED_ROFI_MESSAGE_BORDER@px;
    border-color: #263645;
    border-radius: @DOTFILES_UI_RESOLVED_ROFI_MESSAGE_RADIUS@px;
    background-color: @bg-alt;
}

textbox {
    text-color: @fg;
}
