#!/usr/bin/env bash

set -euo pipefail

chrome_bin="${GOOGLE_CHROME_BIN:-}"

if [[ -z "$chrome_bin" ]]; then
  for candidate in google-chrome-stable google-chrome chromium chromium-browser; do
    if chrome_bin="$(command -v "$candidate")"; then
      break
    fi
    chrome_bin=""
  done
fi

if [[ -z "$chrome_bin" || ! -x "$chrome_bin" ]]; then
  echo "Unable to find an executable Chrome/Chromium binary." >&2
  exit 127
fi

exec env GTK_USE_PORTAL=1 "$chrome_bin" "$@"
